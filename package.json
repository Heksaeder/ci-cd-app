{
  "homepage": "https://<username>.github.io/ci-cd-ynov",
  "scripts": {
    "test": "react-scripts test --coverage --watchAll=false --collectCoverageFrom=src/**/*.js --collectCoverageFrom=!src/index.js --collectCoverageFrom=!src/reportWebVitals.js",
    "build": "react-scripts build",
    "jsdoc": "jsdoc -R ./README.md -c ./jsdoc.config.json -r -d ./public/docs src",
    "build-npm-ci": "NODE_ENV=production && rm -rf dist && mkdir dist && npx babel src --out-dir dist --copy-files"
  },
  "jest": {
    "coverageThreshold": {
      "global": { "branches": 100, "functions": 100, "lines": 100, "statements": 100 }
    }
  }
}